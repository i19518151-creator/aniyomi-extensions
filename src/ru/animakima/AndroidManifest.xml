<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="eu.kanade.tachiyomi.animeextension.ru.animakima">

    <application
        android:allowBackup="false"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="${appName}"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true">

        <meta-data
            android:name="tachiyomi.extension.class"
            android:value="${extClass}" />

        <meta-data
            android:name="tachiyomi.extension.name"
            android:value="Animakima" />

        <meta-data
            android:name="tachiyomi.extension.lang"
            android:value="ru" />

        <meta-data
            android:name="tachiyomi.extension.version"
            android:value="${versionId}" />

        <meta-data
            android:name="tachiyomi.extension.nsfw"
            android:value="${nsfw}" />
    </application>

</manifest>
